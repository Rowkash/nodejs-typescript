{
  "name": "node-typescript-template",
  "version": "1.0.0",
  "description": "Node.js template with TypeScript, Eslint and Prettier",
  "author": "Ruslan Hamzin",
  "keywords": [
    "node.js",
    "typescript"
  ],
  "license": "MIT",
  "scripts": {
    "start:dev": "tsx --env-file=.env --watch ./src/main.ts",
    "start:prod": "node dist/main.js",
    "type-check": "tsc --noEmit --watch",
    "clean": "rimraf ./dist",
    "build": "pnpm clean && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.json",
    "build-prod": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.json",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
